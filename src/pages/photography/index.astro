---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import WorkGrid from "@components/WorkGrid.astro";
import { published } from "@lib/content";
import { entrySlug } from "@lib/content";
import { getGalleryCover } from "@lib/gallery-images";

const photos = published(await getCollection("photography"));
const pageCover = photos[0] ? getGalleryCover(entrySlug(photos[0]), photos[0].data.coverImage, photos[0].data.images) : "";
const defaultPhotographyType = "corporate-private-events";
const photographySections = [
  {
    id: "corporate-private-events",
    label: "Corporate & private events",
    items: photos.filter((photo) => photo.data.photographyType === "corporate-private-events")
  },
  {
    id: "stage-work",
    label: "Stage work",
    items: photos.filter((photo) => photo.data.photographyType === "stage-work")
  },
  {
    id: "photoshoot",
    label: "Photoshoot",
    items: photos.filter((photo) => photo.data.photographyType === "photoshoot")
  },
  {
    id: "wedding-rom",
    label: "Wedding & ROM",
    items: photos.filter((photo) => photo.data.photographyType === "wedding-rom")
  },
  {
    id: "all",
    label: "All",
    items: photos
  }
];
---

<BaseLayout title="Photography" description="Corporate event photography portfolio with scalable gallery listings." active="photography" image={pageCover}>
  <section class="page-hero photography-page-hero" aria-labelledby="photography-title">
    <p class="eyebrow">Photography showcase</p>
    <h1 id="photography-title">Corporate events presented with restraint.</h1>
    <p>Clean off-white space, consistent sans-serif typography, and galleries that preserve the natural shape of each image.</p>
  </section>

  <section class="gallery-index-section photography-browser" aria-label="Photography galleries">
    <div class="photography-tabs" role="tablist" aria-label="Photography categories">
      {
        photographySections.map((section) => (
          <button
            class:list={["photography-tab", { "is-active": section.id === defaultPhotographyType }]}
            type="button"
            role="tab"
            aria-selected={section.id === defaultPhotographyType ? "true" : "false"}
            aria-controls={`photography-panel-${section.id}`}
            id={`photography-tab-${section.id}`}
            data-photography-tab={section.id}
          >
            {section.label}
          </button>
        ))
      }
    </div>
    {
      photographySections.map((section) => (
        <section
          class="photography-panel"
          id={`photography-panel-${section.id}`}
          role="tabpanel"
          aria-labelledby={`photography-tab-${section.id}`}
          data-photography-panel={section.id}
          hidden={section.id !== defaultPhotographyType}
        >
          {section.items.length > 0 ? <WorkGrid items={section.items} /> : <p class="empty-gallery-note">No published galleries in this section yet.</p>}
        </section>
      ))
    }
  </section>

  <script>
    const tabs = Array.from(document.querySelectorAll<HTMLElement>("[data-photography-tab]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-photography-panel]"));

    function selectPhotographySection(id: string) {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.photographyTab === id;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", String(isActive));
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.photographyPanel !== id;
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => selectPhotographySection(tab.dataset.photographyTab || "corporate-private-events"));
    });
  </script>

  <section class="page-cta" aria-labelledby="photo-contact-title">
    <h2 id="photo-contact-title">Need corporate event coverage?</h2>
    <p>Reach out for conferences, panels, networking events, or content packages.</p>
    <a class="button button-dark" href="/contact/">Contact me</a>
  </section>
</BaseLayout>
