---
import { site } from "@lib/site";
---

<section class="home-contact" aria-labelledby="home-contact-title">
  <p class="eyebrow">Contact</p>
  <h2 id="home-contact-title">For shoots, collaborations, or analytics work.</h2>
  <p>Reach me directly through WhatsApp or Gmail. The dedicated contact page keeps these links accessible without cluttering the photography and data pages.</p>
  <div class="contact-actions">
    <a class="button button-dark" href={site.whatsappUrl}>WhatsApp</a>
    <a class="button button-quiet" href={`mailto:${site.email}`}>Email</a>
  </div>
</section>
