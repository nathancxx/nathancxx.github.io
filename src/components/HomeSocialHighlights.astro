---
import type { ContentWorkEntry } from "@lib/content";
import { displayTitle } from "@lib/content";

interface Props {
  items: ContentWorkEntry[];
}

const { items } = Astro.props;
const categories = [
  { id: "corporate", label: "Corporate" },
  { id: "lifestyle", label: "Lifestyle" },
  { id: "real-estate", label: "Real estate" }
] as const;
type Category = (typeof categories)[number];
type SelectedItem = {
  category: Category;
  item: ContentWorkEntry;
};

const platformLabels: Record<ContentWorkEntry["data"]["platform"], string> = {
  instagram: "Instagram",
  tiktok: "TikTok",
  linkedin: "LinkedIn"
};

const selectedItems: SelectedItem[] = categories
  .map((category) => {
    const categoryItems = items.filter((item) => item.data.socialCategory === category.id);
    if (categoryItems.length === 0) return null;

    return {
      category,
      item: pickBestByLikes(categoryItems)
    };
  })
  .filter((entry): entry is SelectedItem => entry !== null);

function pickBestByLikes(categoryItems: ContentWorkEntry[]) {
  const withLikes = categoryItems
    .map((item, index) => ({
      item,
      index,
      likes: getMetricValue(item, "like")
    }))
    .filter((entry) => entry.likes !== null);

  if (withLikes.length === 0) return categoryItems[0];

  return withLikes.sort((a, b) => b.likes! - a.likes! || a.index - b.index)[0].item;
}

function getMetricValue(item: ContentWorkEntry, labelNeedle: string) {
  const metric = item.data.metrics.find((entry) => entry.label.toLowerCase().includes(labelNeedle));
  if (!metric) return null;

  const value = parseMetricNumber(metric.value);
  return Number.isFinite(value) ? value : null;
}

function parseMetricNumber(value: string) {
  const normalized = String(value || "").trim().toLowerCase().replace(/,/g, "");
  const match = normalized.match(/^(\d+(?:\.\d+)?)(k|m)?\+?$/);
  if (!match) return Number.NaN;

  const base = Number(match[1]);
  const multiplier = match[2] === "m" ? 1_000_000 : match[2] === "k" ? 1_000 : 1;
  return base * multiplier;
}

function categoryUrl(category: Category) {
  return `/content/?category=${category.id}`;
}

function firstSentence(item: ContentWorkEntry) {
  const body = String(item.body || "");
  const aiCopy = extractAiSummary(body);
  const source = aiCopy || item.data.summary || "";
  const sentence = source.replace(/\s+/g, " ").trim().match(/[^.!?]+[.!?]/);
  return sentence ? sentence[0].trim() : source.replace(/\s+/g, " ").trim();
}

function extractAiSummary(body: string) {
  const start = "{/* ai-summary:start */}";
  const end = "{/* ai-summary:end */}";
  const startIndex = body.indexOf(start);
  const endIndex = body.indexOf(end);
  if (startIndex === -1 || endIndex === -1 || endIndex <= startIndex) return "";
  return body.slice(startIndex + start.length, endIndex).trim();
}
---

{
  selectedItems.length > 0 && (
    <section class="home-section home-social-work" aria-labelledby="home-social-title">
      <div class="home-section-heading">
        <p class="eyebrow">Social media reels</p>
        <div>
          <h2 id="home-social-title">Short-form content.</h2>
          <p>
            Instagram and TikTok-ready reels for influencers, high-net-worth individuals, and companies that need polished stories with clear commercial use.
          </p>
        </div>
      </div>

      <div class="home-social-grid">
        {
          selectedItems.map(({ category, item }) => {
            const title = displayTitle(item);
            const url = categoryUrl(category);
            const description = firstSentence(item);
            return (
              <article class="home-social-card">
                <span class="meta-label">{category.label}</span>
                <div class={`home-social-player home-social-player-${item.data.platform}`}>
                  {
                    item.data.embedHtml ? (
                      <div class="home-social-embed" set:html={item.data.embedHtml} />
                    ) : item.data.coverImage ? (
                      <a href={item.data.externalUrl || "/content/"} target="_blank" rel="noreferrer">
                        <img src={item.data.coverImage} alt={title} loading="lazy" />
                      </a>
                    ) : item.data.externalUrl ? (
                      <a class="home-social-direct-window" href={item.data.externalUrl} target="_blank" rel="noreferrer">
                        Open {platformLabels[item.data.platform]} post
                      </a>
                    ) : (
                      <div class="home-social-direct-window">Add an embed or preview image</div>
                    )
                  }
                </div>
                <div class="home-social-copy">
                  <h3>{title}</h3>
                  {description && <p>{description}</p>}
                  <div
                    class:list={["content-metrics", "home-social-metrics", { "is-empty": item.data.metrics.length === 0 }]}
                    aria-label={`${title} metrics`}
                    aria-hidden={item.data.metrics.length === 0 ? "true" : "false"}
                  >
                    {item.data.metrics.map((metric: ContentWorkEntry["data"]["metrics"][number]) => (
                      <span>
                        <strong>{metric.value}</strong>
                        {metric.label}
                      </span>
                    ))}
                  </div>
                  <a class="home-social-more" href={url}>
                    <span aria-hidden="true">+</span>
                    View more
                  </a>
                </div>
              </article>
            );
          })
        }
      </div>
    </section>
  )
}
